# Copy this file to key.properties and fill in your values.
# NEVER commit key.properties or your .jks keystore to version control.
#
# Generate a keystore with:
#   keytool -genkey -v \
#     -keystore ~/keys/appvariant-release.jks \
#     -alias appvariant \
#     -keyalg RSA \
#     -keysize 2048 \
#     -validity 10000
storePassword=your_store_password
keyPassword=your_key_password
keyAlias=your_key_alias
storeFile=/absolute/path/to/your/keystore.jks
